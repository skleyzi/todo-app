generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Task {
  id         String    @id @default(cuid())
  title      String
  category   String?
  dueDate    DateTime?
  priority   Int       @default(5)
  done       Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}
